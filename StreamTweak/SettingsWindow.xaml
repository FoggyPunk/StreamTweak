<Window x:Class="StreamTweak.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StreamTweak" Height="510" Width="680"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource TextForeground}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackground" Color="#FFF3F3F3"/>
        <SolidColorBrush x:Key="PanelBackground" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="TextForeground" Color="#FF202020"/>
        <SolidColorBrush x:Key="BorderColor" Color="#FFD1D1D1"/>
        <SolidColorBrush x:Key="AccentColor" Color="{x:Static SystemParameters.WindowGlassColor}"/>
        <SolidColorBrush x:Key="AccentHoverColor" Color="#FF106EBE"/>

        <!-- Toggle Switch Style -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Track" Grid.Column="0" Width="40" Height="22"
                                    CornerRadius="11" Background="{DynamicResource BorderColor}">
                                <Ellipse x:Name="Thumb" Width="16" Height="16" Fill="White"
                                         HorizontalAlignment="Left" Margin="3,0,0,0"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" Margin="8,0,0,0"
                                              VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentColor}"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="21,0,0,0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="MainBorder" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6"/>
                            <Grid Margin="8,0">
                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"
                                                  Content="{TemplateBinding SelectionBoxItem}"/>
                                <Path HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"
                                      Data="M 0 0 L 4 4 L 8 0" Stroke="{TemplateBinding Foreground}"
                                      StrokeThickness="2" StrokeEndLineCap="Round"/>
                            </Grid>
                            <ToggleButton Background="Transparent" BorderThickness="0" Focusable="False"
                                          FocusVisualStyle="{x:Null}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=MainBorder}"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, ElementName=MainBorder}"
                                        Background="{DynamicResource PanelBackground}"
                                        BorderBrush="{DynamicResource BorderColor}"
                                        BorderThickness="1" CornerRadius="6" Margin="0,4,0,0">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button Styles -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BorderColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentHoverColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Tab Button Style -->
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TabButtonActive" TargetType="Button" BasedOn="{StaticResource TabButton}">
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20,16,20,16">

        <!-- Tab Buttons + Content -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tab selector buttons -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <Button x:Name="NetworkTabButton"
                        Style="{StaticResource TabButtonActive}"
                        Margin="0,0,10,0"
                        Click="NetworkTabButton_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE839;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" FontWeight="Normal"
                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Network" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
                <Button x:Name="DisplayTabButton"
        Style="{StaticResource TabButton}"
        Margin="0,0,10,0"
        Click="DisplayTabButton_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets"
                   FontSize="14" FontWeight="Normal"
                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Display" VerticalAlignment="Center"
                   FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
                <Button x:Name="AudioTabButton"
                        Style="{StaticResource TabButton}"
                        Margin="0,0,10,0"
                        Click="AudioTabButton_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE7F6;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" FontWeight="Normal"
                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Audio" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
                <Button x:Name="LogsTabButton"
                        Style="{StaticResource TabButton}"
                        Margin="0,0,10,0"
                        Click="LogsTabButton_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" FontWeight="Normal"
                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Logs" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
                <Button x:Name="AboutTabButton"
                        Style="{StaticResource TabButton}"
                        Click="AboutTabButton_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" FontWeight="Normal"
                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="About" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
                <Button x:Name="ThemeToggleButton" Content="🌙" Margin="30,0,0,0"
                        Style="{StaticResource ModernButton}" Width="36" Height="28" Padding="2,2"
                        VerticalAlignment="Center" Click="ThemeToggleButton_Click"/>
            </StackPanel>

            <!-- ═══════════════ NETWORK PANEL ═══════════════ -->
            <Border x:Name="NetworkPanel" Grid.Row="1"
                    Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="10" Padding="14,12,14,14" TextElement.Foreground="{DynamicResource TextForeground}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>     <!-- 0: top spacer -->
                        <RowDefinition Height="Auto"/>  <!-- 1: adapter label -->
                        <RowDefinition Height="Auto"/>  <!-- 2: adapter combo -->
                        <RowDefinition Height="Auto"/>  <!-- 3: current speed -->
                        <RowDefinition Height="Auto"/>  <!-- 4: target speed label -->
                        <RowDefinition Height="Auto"/>  <!-- 5: target speed combo -->
                        <RowDefinition Height="16"/>    <!-- 6: spacer -->
                        <RowDefinition Height="Auto"/>  <!-- 7: separator -->
                        <RowDefinition Height="Auto"/>  <!-- 8: toggle -->
                        <RowDefinition Height="Auto"/>  <!-- 9: description -->
                        <RowDefinition Height="16"/>    <!-- 10: spacer -->
                        <RowDefinition Height="Auto"/>  <!-- 11: buttons -->
                        <RowDefinition Height="Auto"/>  <!-- 12: info text -->
                    </Grid.RowDefinitions>

                    <!-- Adapter -->
                    <TextBlock Text="Select Physical Network Adapter:" FontWeight="Medium" HorizontalAlignment="Center" Margin="0,0,0,5" Grid.Row="1"/>
                    <ComboBox x:Name="AdapterComboBox" Margin="0,0,0,10" Grid.Row="2"
                              SelectionChanged="AdapterComboBox_SelectionChanged"/>

                    <!-- Current Speed -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <TextBlock Text="Current Speed:" FontWeight="Medium" Margin="0,0,10,0"/>
                        <TextBlock x:Name="CurrentSpeedTextBlock" Text="Detecting..." FontWeight="Bold"
                                   Foreground="{DynamicResource AccentColor}"/>
                    </StackPanel>

                    <!-- Target Speed -->
                    <TextBlock Text="Target Link Speed:" FontWeight="Medium" HorizontalAlignment="Center" Margin="0,0,0,5" Grid.Row="4"/>
                    <ComboBox x:Name="SpeedComboBox" Margin="0,0,0,10" Grid.Row="5"/>

                    <!-- Separator -->
                    <Separator Grid.Row="7" Margin="0,0,0,10" Background="{DynamicResource BorderColor}"/>

                    <!-- Auto Streaming Mode Toggle -->
                    <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Auto Streaming Mode" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <CheckBox x:Name="AutoStreamingToggle" Style="{StaticResource ToggleSwitchStyle}"
                                  VerticalAlignment="Center" Checked="AutoStreamingToggle_Changed"
                                  Unchecked="AutoStreamingToggle_Changed"/>
                    </StackPanel>

                    <StackPanel Grid.Row="9" Orientation="Vertical" Margin="0,12,0,0">
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextForeground}" Opacity="0.7" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,3" LineHeight="16">
                            <Run Text="Auto-sets network speed to 1Gbps when Moonlight streams."/>
                        </TextBlock>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextForeground}" Opacity="0.7" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,3" LineHeight="16">
                            <Run Text="⚠️ A brief disconnect will occur during speed adjustment."/>
                        </TextBlock>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextForeground}" Opacity="0.7" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,0" LineHeight="16">
                            <Run Text="Reconnect within 30 seconds or the original speed will be restored."/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Buttons -->
                    <Grid Grid.Row="11" Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="StreamingModeButton" Content="Start Streaming Mode"
                                Height="42" Click="StreamingModeButton_Click"
                                Style="{StaticResource ModernButton}" HorizontalAlignment="Stretch"/>
                        <Image Grid.Column="1" Source="pack://application:,,,/Resources/streamtweak.ico" Width="24" Height="24"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12,0"/>
                        <Button Grid.Column="2" Content="Apply Settings" Height="42"
                                Click="ApplyButton_Click" Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Stretch"/>
                    </Grid>

                    <!-- Info Text -->
                    <TextBlock Grid.Row="12" FontSize="11" Foreground="{DynamicResource TextForeground}" Opacity="0.7"
                               TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0">
                        <InlineUIContainer BaselineAlignment="Center">
                            <Image Source="pack://application:,,,/Resources/streammodeok.ico"
                                   Width="14" Height="14" Margin="0,0,4,0"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </InlineUIContainer>
                        <Run Text="Streaming Mode auto-sets the Target Link Speed to 1Gbps. Stop to revert to original Speed."/>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- ═══════════════ DISPLAY PANEL ═══════════════ -->
            <Border x:Name="DisplayPanel" Grid.Row="1" Visibility="Collapsed"
        Background="{DynamicResource PanelBackground}"
        BorderBrush="{DynamicResource BorderColor}"
        BorderThickness="1" CornerRadius="10"
        Padding="14,12,14,12"
        TextElement.Foreground="{DynamicResource TextForeground}">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- 0: context label -->
                        <RowDefinition Height="Auto"/>  <!-- 1: separator -->
                        <RowDefinition Height="Auto"/>  <!-- 2: loading text -->
                        <RowDefinition Height="*"/>     <!-- 3: monitor list (scrollable) -->
                        <RowDefinition Height="Auto"/>  <!-- 4: refresh button -->
                        <RowDefinition Height="Auto"/>  <!-- 5: AutoHDR section -->
                    </Grid.RowDefinitions>

                    <!-- ── Context label (streaming app / virtual display) ── -->
                    <StackPanel x:Name="DisplayContextLabel"
                       Grid.Row="0"
                       Orientation="Horizontal"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,0,0,6"
                       Visibility="Collapsed">
                        <Image x:Name="DisplayContextIcon"
                               Width="14" Height="14"
                               Margin="0,0,5,0"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock x:Name="DisplayContextText"
                                   FontSize="10" Opacity="0.6"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextForeground}"/>
                    </StackPanel>

                    <!-- ── Separator ── -->
                    <Separator Grid.Row="1" Background="{DynamicResource BorderColor}" Margin="0,0,0,10"/>

                    <!-- ── Loading / error text ── -->
                    <TextBlock x:Name="DisplayLoadingText"
                   Grid.Row="2"
                   Text="Reading display info…"
                   FontSize="12" Opacity="0.6"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,8"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource TextForeground}"/>

                    <!-- ── Monitor list ── -->
                    <ScrollViewer Grid.Row="3"
                      VerticalScrollBarVisibility="Auto"
                      MaxHeight="195"
                      Margin="0,0,0,0">
                        <StackPanel x:Name="MonitorStackPanel"
                        Visibility="Collapsed"/>
                    </ScrollViewer>

                    <!-- ── Refresh button ── -->
                    <Button Grid.Row="4"
                            Style="{StaticResource ModernButton}"
                            Width="50" Height="24" Padding="0,2" FontSize="11"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,0"
                            Click="DisplayRefreshButton_Click">Refresh</Button>

                    <!-- ── AutoHDR section ── -->
                    <StackPanel x:Name="AutoHdrSection"
                    Grid.Row="5"
                    Visibility="Collapsed"
                    Margin="0,8,0,0">

                        <Separator Background="{DynamicResource BorderColor}" Margin="0,0,0,10"/>

                        <Border Padding="12,10"
                    BorderThickness="1" CornerRadius="6"
                    Background="{DynamicResource WindowBackground}"
                    BorderBrush="{DynamicResource BorderColor}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Auto HDR" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextForeground}"/>
                                    <TextBlock Text="Enables Windows Auto HDR for supported SDR games."
                                   FontSize="10" Opacity="0.6" Margin="0,2,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextForeground}"/>
                                    <TextBlock Text="Changes apply immediately. Reopen Windows Settings to see them reflected there."
                                   FontSize="10" Opacity="0.6"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextForeground}"/>
                                    <TextBlock x:Name="AutoHdrWarning"
                                   Visibility="Collapsed"
                                   Text="⚠  Auto HDR requires at least one display with HDR enabled."
                                   FontSize="10"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="#FFC107"/>
                                </StackPanel>

                                <CheckBox x:Name="AutoHdrToggle"
                              Grid.Column="1"
                              Style="{StaticResource ToggleSwitchStyle}"
                              VerticalAlignment="Center"
                              Checked="AutoHdrToggle_Changed"
                              Unchecked="AutoHdrToggle_Changed"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                </Grid>
            </Border>

            <!-- ═══════════════ AUDIO PANEL ═══════════════ -->
            <Border x:Name="AudioPanel" Grid.Row="1" Visibility="Collapsed"
                    Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1" CornerRadius="10" Padding="14,12,14,14"
                    TextElement.Foreground="{DynamicResource TextForeground}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>     <!-- 0: top spacer -->
                        <RowDefinition Height="Auto"/>  <!-- 1: title -->
                        <RowDefinition Height="Auto"/>  <!-- 2: Dolby Access status -->
                        <RowDefinition Height="Auto"/>  <!-- 3: separator -->
                        <RowDefinition Height="Auto"/>  <!-- 4: toggle -->
                        <RowDefinition Height="Auto"/>  <!-- 5: description -->
                        <RowDefinition Height="16"/>    <!-- 6: spacer -->
                        <RowDefinition Height="Auto"/>  <!-- 7: monitor status -->
                        <RowDefinition Height="*"/>     <!-- 8: bottom spacer -->
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <TextBlock Text="&#xE7F6;" FontFamily="Segoe MDL2 Assets" FontSize="26"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"
                                   Foreground="{DynamicResource AccentColor}"/>
                        <TextBlock Text="Steam Streaming Speakers Monitor" FontSize="14" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Dolby Access detection status -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <TextBlock x:Name="DolbyAccessIcon" Text="●" FontSize="9"
                                   VerticalAlignment="Center" Margin="0,0,5,0"
                                   Foreground="Gray"/>
                        <TextBlock x:Name="DolbyAccessText" FontSize="11" VerticalAlignment="Center"
                                   Text="Checking Dolby Access…"
                                   Foreground="{DynamicResource TextForeground}" Opacity="0.7"/>
                    </StackPanel>

                    <!-- Separator -->
                    <Separator Grid.Row="3" Background="{DynamicResource BorderColor}" Margin="0,0,0,16"/>

                    <!-- Toggle -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center"
                                VerticalAlignment="Center" Margin="0,0,0,14">
                        <TextBlock Text="Auto Dolby Atmos for Headphones" FontWeight="SemiBold" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <CheckBox x:Name="DolbyMonitorToggle" Style="{StaticResource ToggleSwitchStyle}"
                                  VerticalAlignment="Center" Checked="DolbyMonitorToggle_Changed"
                                  Unchecked="DolbyMonitorToggle_Changed"/>
                    </StackPanel>

                    <!-- Description -->
                    <StackPanel Grid.Row="5" Orientation="Vertical">
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextForeground}" Opacity="0.7"
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,3" LineHeight="16">
                            <Run Text="When a streaming session is detected and stays active for 30 seconds,"/>
                        </TextBlock>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextForeground}" Opacity="0.7"
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,3" LineHeight="16">
                            <Run Text="Dolby Atmos for Headphones is enabled on Steam Streaming Speakers"/>
                        </TextBlock>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextForeground}" Opacity="0.7"
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,0" LineHeight="16">
                            <Run Text="if Dolby Access is installed and the format is available."/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Monitor status box -->
                    <Border Grid.Row="7" Padding="10,8"
                            Background="{DynamicResource WindowBackground}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1" CornerRadius="6">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Status:" FontSize="11" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="0,0,6,0"
                                       Foreground="{DynamicResource TextForeground}"/>
                            <TextBlock x:Name="DolbyStatusText" FontSize="11" VerticalAlignment="Center"
                                       Text="Disabled" Foreground="{DynamicResource TextForeground}" Opacity="0.7"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══════════════ LOGS PANEL ═══════════════ -->
            <Border x:Name="LogsPanel" Grid.Row="1" Visibility="Collapsed"
                    Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="10" Padding="14,12,14,14" TextElement.Foreground="{DynamicResource TextForeground}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Column headers -->
                    <Grid Grid.Row="0" Margin="0,0,0,6" HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="155"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Date / Time"  FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" Foreground="{DynamicResource TextForeground}"/>
                        <TextBlock Grid.Column="1" Text="Mode"         FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" Foreground="{DynamicResource TextForeground}"/>
                        <TextBlock Grid.Column="2" Text="Duration"     FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" Foreground="{DynamicResource TextForeground}"/>
                        <TextBlock Grid.Column="3" Text="Original Speed" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" Foreground="{DynamicResource TextForeground}"/>
                    </Grid>

                    <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="{DynamicResource BorderColor}" Margin="0,24,0,0"/>

                    <!-- Session list -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                        <ItemsControl x:Name="SessionHistoryList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6" HorizontalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="65"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="155"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding StartTimeDisplay}" FontSize="11" HorizontalAlignment="Center" Foreground="{DynamicResource TextForeground}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TriggerMode}"      FontSize="11" HorizontalAlignment="Center" Foreground="{DynamicResource TextForeground}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding DurationDisplay}"  FontSize="11" HorizontalAlignment="Center" Foreground="{DynamicResource TextForeground}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding OriginalSpeed}"    FontSize="11" HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource AccentColor}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Empty state -->
                    <TextBlock x:Name="NoHistoryLabel" Grid.Row="1"
                               Text="No sessions recorded yet." FontSize="11"
                               Foreground="{DynamicResource TextForeground}" Opacity="0.7" HorizontalAlignment="Center"
                               VerticalAlignment="Center" Visibility="Collapsed"/>

                    <!-- Clear button + Stream host label -->
                    <StackPanel Grid.Row="2" Margin="0,10,0,4" HorizontalAlignment="Center">
                        <Button x:Name="ClearLogsButton"
                                HorizontalAlignment="Center"
                                Style="{StaticResource ModernButton}"
                                FontSize="11" Height="22" Width="195"
                                ToolTip="Clear session history"
                                Click="ClearLogsButton_Click">Clear Session History</Button>
                        <TextBlock Text="Stream host log folder"
                                   FontSize="9" Opacity="0.7"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"
                                   Foreground="{DynamicResource TextForeground}"/>
                    </StackPanel>

                    <!-- Detected streaming software -->
                    <Border Grid.Row="3" Padding="8,7"
                            Background="{DynamicResource WindowBackground}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <StackPanel x:Name="StreamingAppFoundPanel" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Image x:Name="StreamingAppIconImage" Width="22" Height="22"
                                       Margin="0,0,8,0" VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="StreamingAppNameText"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextForeground}"/>
                                    <TextBlock x:Name="StreamingAppLogPathText"
                                               FontSize="10" Opacity="0.6"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,1,0,0"
                                               Foreground="{DynamicResource TextForeground}"
                                               Cursor="Hand"
                                               ToolTip="Click to open log folder"
                                               MouseLeftButtonUp="StreamingAppLogPathText_Click"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock x:Name="StreamingAppNotFoundText"
                                       Text="No streaming software detected"
                                       FontSize="10" Opacity="0.6"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextForeground}"
                                       Visibility="Collapsed"/>
                        </Grid>
                    </Border>

                    <!-- Footer -->
                    <TextBlock Grid.Row="4" FontSize="9" Foreground="{DynamicResource TextForeground}" Opacity="0.7"
                               TextAlignment="Center" Margin="0,8,0,0">
                        <Run Text="Last 10 sessions — Auto &amp; Manual tracked  ·  ⚡ = not properly closed from Moonlight"/>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- ═══════════════ ABOUT PANEL ═══════════════ -->
            <Border x:Name="AboutPanel" Grid.Row="1" Visibility="Collapsed"
                    Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1" CornerRadius="10" Padding="14,24,14,24"
                    TextElement.Foreground="{DynamicResource TextForeground}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!-- App Icon -->
                    <Image Source="pack://application:,,,/Resources/streamtweak.ico"
                           Width="56" Height="56" HorizontalAlignment="Center"
                           Margin="0,0,0,10" RenderOptions.BitmapScalingMode="HighQuality"/>

                    <!-- App Name -->
                    <TextBlock Text="StreamTweak" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,3"
                               Foreground="{DynamicResource TextForeground}"/>

                    <!-- Version -->
                    <TextBlock x:Name="AboutVersionText" FontSize="12"
                               HorizontalAlignment="Center" Opacity="0.65" Margin="0,0,0,14"
                               Foreground="{DynamicResource TextForeground}"/>

                    <!-- Developer + Build (compact) -->
                    <TextBlock Text="Developed by FoggyBytes" FontSize="12" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,2"
                               Foreground="{DynamicResource TextForeground}"/>
                    <TextBlock x:Name="AboutBuildDateText" FontSize="11" Opacity="0.55"
                               HorizontalAlignment="Center" Margin="0,0,0,0"
                               Foreground="{DynamicResource TextForeground}"/>

                    <!-- Update check -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                            <TextBlock x:Name="UpdateStatusText" FontSize="11" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextForeground}" Opacity="0.7"
                                       Margin="0,0,8,0"/>
                            <Button x:Name="CheckUpdateButton" Content="Check for updates" Height="26"
                                    Style="{StaticResource ModernButton}" FontSize="11" Width="140"
                                    Click="CheckUpdateButton_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="UpdateLinkText" Text="⬇ Download latest version" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,5,0,0" Cursor="Hand"
                                   Foreground="{DynamicResource AccentColor}" Visibility="Collapsed"
                                   MouseLeftButtonUp="UpdateLinkText_Click"/>
                    </StackPanel>

                    <!-- Separator -->
                    <Separator Background="{DynamicResource BorderColor}" Margin="0,0,0,16" Width="260"/>

                    <!-- GPL Badge -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Cursor="Hand"
                                MouseLeftButtonUp="GplBadge_Click" Margin="0,0,0,14">
                        <Border Background="#555555" CornerRadius="3,0,0,3" Padding="7,5">
                            <TextBlock Text="License" FontSize="11" Foreground="White" FontFamily="Segoe UI"/>
                        </Border>
                        <Border Background="#4caf50" CornerRadius="0,3,3,0" Padding="7,5">
                            <TextBlock Text="GPL v3" FontSize="11" Foreground="White"
                                       FontFamily="Segoe UI" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <!-- GitHub + Donate buttons (side by side) -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                        <Button Width="152" Height="36" Margin="0,0,8,0" Click="GitHubButton_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                                    <Setter Property="Background" Value="#24292e"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3a4148"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8F7;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="13" FontWeight="Normal"
                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="View on GitHub" VerticalAlignment="Center"
                                           FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                        <Button Width="152" Height="36" Click="DonateButton_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                                    <Setter Property="Background" Value="#0070BA"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#005EA6"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="💳" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Donate via PayPal" VerticalAlignment="Center"
                                           FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>

                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</Window>

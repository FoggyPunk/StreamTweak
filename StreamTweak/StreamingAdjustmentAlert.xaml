<Window x:Class="StreamTweak.StreamingAdjustmentAlert"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StreamTweak" Height="240" Width="380"
        WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize"
        WindowStyle="None"
        Topmost="True"
        Background="#FFF3F3F3"
        Foreground="#FF202020"
        FontFamily="Segoe UI"
        Icon="pack://application:,,,/Resources/streamtweak.ico">

    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <Image Source="pack://application:,,,/Resources/streamtweak.ico" Width="48" Height="48" 
                   HorizontalAlignment="Center" Margin="0,0,0,12"/>

            <TextBlock Text="⚙️ Adjusting Network Speed" 
                       FontWeight="Bold" FontSize="14" TextAlignment="Center" Margin="0,0,0,12"/>

            <TextBlock Text="Setting network speed to 1Gbps for optimal streaming." 
                       FontSize="11" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,10"/>

            <TextBlock Text="Your stream will briefly disconnect. Reconnect within 30 seconds or speed will revert to original." 
                       FontSize="10" TextAlignment="Center" TextWrapping="Wrap" Foreground="#FF606060" Margin="0,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>

<Application x:Class="StreamTweak.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar">
    <Application.Resources>
        <tb:TaskbarIcon x:Key="MyNotifyIcon"
                        ToolTipText="StreamTweak"
                        TrayMouseDoubleClick="TaskbarIcon_TrayMouseDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Settings..." Click="MenuSettings_Click" FontWeight="Bold"/>
                    <Separator/>
                    <MenuItem x:Name="SpeedStatusMenuItem"  Header="Speed: —"             IsEnabled="False"/>
                    <MenuItem x:Name="StreamingStatusMenuItem" Header="Streaming: Inactive" IsEnabled="False"/>
                    <Separator/>
                    <MenuItem x:Name="StreamingModeMenuItem" Header="Start Streaming Mode" Click="MenuStreamingMode_Click"/>
                    <MenuItem x:Name="AutoModeMenuItem"      Header="Auto Mode: Enabled"
                              IsCheckable="True" IsChecked="True" Click="MenuAutoMode_Click"/>
                    <MenuItem x:Name="DolbyModeMenuItem"     Header="Dolby Atmos: Disabled"
                              IsCheckable="True" IsChecked="False" Click="MenuDolbyMode_Click"/>
                    <Separator/>
                    <MenuItem Header="Exit" Click="MenuExit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Application.Resources>
</Application>
